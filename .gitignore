# z88dk per-source intermediates — kept beside their sources (see CLAUDE.md),
# not routed into build/.
*.lis
*.lst
*.bin
*.tap
*.map
*.o
*.dep
*.sym
*.c.asm

# All final build artifacts (ZX main + main.tap, CPC .dsk + named binaries, test
# taps, host unit-test binaries, emulator screenshots) are emitted here.
# `make clean` removes it wholesale (rm -rf build/).
build/
